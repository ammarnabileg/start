# ============================================================
# AI Recruitment SaaS Platform — Environment Configuration
# Copy this file to .env and fill in your values.
# The Setup Wizard (setup/index.php) will generate this automatically.
# ============================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="AI Recruitment Platform"
APP_URL=http://localhost
APP_ENV=production
APP_KEY=
APP_DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ai_recruitment
DB_USERNAME=root
DB_PASSWORD=

# ── Authentication (JWT) ──────────────────────────────────────────────────────
# JWT_SECRET must be a random 64-character hex string. Generated automatically.
JWT_SECRET=
JWT_EXPIRY=86400

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="AI Recruitment Platform"
MAIL_ENCRYPTION=tls

# ── File Uploads ──────────────────────────────────────────────────────────────
# UPLOAD_MAX_SIZE in kilobytes (e.g. 10240 = 10 MB)
UPLOAD_MAX_SIZE=10240
UPLOAD_ALLOWED_TYPES=pdf,doc,docx,jpg,jpeg,png,gif,mp4,webm

# ── Session ───────────────────────────────────────────────────────────────────
# SESSION_LIFETIME in minutes
SESSION_LIFETIME=120
