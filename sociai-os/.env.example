# ═══════════════════════════════════════════════════════════════════════════════
# SociAI-OS - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Application ────────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ENCRYPTION_KEY=your-fernet-encryption-key-32-url-safe-base64-chars=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
FRONTEND_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=sociai
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_DB=sociai_os
DATABASE_URL=postgresql+asyncpg://sociai:your_secure_postgres_password@localhost:5432/sociai_os

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=your_secure_redis_password
REDIS_URL=redis://:your_secure_redis_password@localhost:6379/0
CELERY_BROKER_URL=redis://:your_secure_redis_password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:your_secure_redis_password@localhost:6379/2

# ─── AI APIs ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
STABILITY_API_KEY=sk-...
ELEVENLABS_API_KEY=...
ELEVENLABS_DEFAULT_VOICE_ID=...

# ─── LinkedIn ────────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/linkedin/callback

# ─── Meta (Instagram + Facebook) ────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/meta/callback

# ─── TikTok ──────────────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/tiktok/callback

# ─── X (Twitter) ─────────────────────────────────────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/twitter/callback

# ─── YouTube (Google OAuth) ──────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/youtube/callback

# ─── Snapchat ────────────────────────────────────────────────────────────────
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
SNAPCHAT_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/snapchat/callback

# ─── Pinterest ───────────────────────────────────────────────────────────────
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/pinterest/callback

# ─── Threads (Meta) ──────────────────────────────────────────────────────────
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/threads/callback

# ─── WhatsApp Business ───────────────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ─── Integrations ────────────────────────────────────────────────────────────
NOTION_TOKEN=
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=
GOOGLE_DRIVE_CREDENTIALS_JSON=

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local  # local | s3 | gcs
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
UPLOAD_DIR=./uploads

# ─── Email ───────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=
FROM_EMAIL=noreply@sociai.io
FROM_NAME=SociAI-OS

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=SociAI OS
PGADMIN_EMAIL=admin@sociai.io
PGADMIN_PASSWORD=admin_secret
