APP_NAME="Watad AI Interviewer"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=watad
DB_USERNAME=watad
DB_PASSWORD=secret

# --- Redis / cache / queue / session ---
REDIS_HOST=redis
REDIS_PORT=6379
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
BROADCAST_CONNECTION=reverb

# --- Reverb (WebSockets) ---
REVERB_APP_ID=watad
REVERB_APP_KEY=watad-key
REVERB_APP_SECRET=watad-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# --- AI: Anthropic (primary) ---
ANTHROPIC_API_KEY=
# Provider used for live interview turns and for deep analysis:
WATAD_AI_PROVIDER=claude
WATAD_AI_CONVERSATION_MODEL=claude-sonnet-4-6
WATAD_AI_ANALYSIS_MODEL=claude-opus-4-8
WATAD_AI_CV_MODEL=claude-opus-4-8

# --- AI: OpenAI (optional alternative provider) ---
OPENAI_API_KEY=
WATAD_OPENAI_CONVERSATION_MODEL=gpt-4o
WATAD_OPENAI_ANALYSIS_MODEL=gpt-4o

# --- Interview budgets ---
WATAD_INTERVIEW_MAX_TOKENS_PER_INTERVIEW=400000
WATAD_INTERVIEW_ABANDON_GRACE_SEC=180
WATAD_INTERVIEW_COVERAGE_TARGET=0.7

# --- Storage (S3-compatible) ---
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=watad
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

# --- Google Sheets ---
WATAD_SHEETS_ENABLED=false
WATAD_SHEETS_SPREADSHEET_ID=
WATAD_SHEETS_TAB=Candidates
GOOGLE_APPLICATION_CREDENTIALS=

# --- Video avatar providers (optional) ---
WATAD_VIDEO_PROVIDER=none
TAVUS_API_KEY=
HEYGEN_API_KEY=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# --- Notifications ---
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS=hello@watad.com
MAIL_FROM_NAME="${APP_NAME}"
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# --- GDPR / retention ---
WATAD_GDPR_RETENTION_DAYS=365
