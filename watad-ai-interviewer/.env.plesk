# =====================================================================
# Watad AI Interviewer — Plesk / shared-hosting environment template
# Copy this file to .env  →  cp .env.plesk .env
# Then fill: APP_KEY (php artisan key:generate), DB_*, OPENAI_API_KEY.
# =====================================================================

APP_NAME="Watad AI Interviewer"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://infallible-aryabhata.198-251-67-150.plesk.page
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Database (fill from Plesk → Databases) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# --- Cache / queue / session: database (no Redis on shared hosting) ---
CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# --- No WebSockets on shared hosting ---
BROADCAST_CONNECTION=null

# --- Local file storage (CVs, report PDFs). NOT s3. ---
FILESYSTEM_DISK=local

# --- AI: OpenAI (active provider) ---
WATAD_AI_PROVIDER=openai
OPENAI_API_KEY=
WATAD_OPENAI_CONVERSATION_MODEL=gpt-4o
WATAD_OPENAI_ANALYSIS_MODEL=gpt-4o

# --- AI: Anthropic (optional; only if you switch provider to claude) ---
ANTHROPIC_API_KEY=
WATAD_AI_CONVERSATION_MODEL=claude-sonnet-4-6
WATAD_AI_ANALYSIS_MODEL=claude-opus-4-8
WATAD_AI_CV_MODEL=claude-opus-4-8

# --- Interview budgets ---
WATAD_INTERVIEW_MAX_TOKENS_PER_INTERVIEW=400000
WATAD_INTERVIEW_ABANDON_GRACE_SEC=180
WATAD_INTERVIEW_COVERAGE_TARGET=0.7

# --- Integrations (off by default) ---
WATAD_SHEETS_ENABLED=false
WATAD_VIDEO_PROVIDER=none
TAVUS_API_KEY=
HEYGEN_API_KEY=

# --- Email (use 'log' until SMTP is configured, then switch to smtp) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@watad.com
MAIL_FROM_NAME="${APP_NAME}"
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# --- GDPR / retention ---
WATAD_GDPR_RETENTION_DAYS=365
