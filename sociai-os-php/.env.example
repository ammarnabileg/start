# SociAI OS Environment Configuration
# Copy this to .env and fill in your values

APP_NAME="SociAI OS"
APP_URL=http://localhost
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=UTC

# ============================================================
# Database
# ============================================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sociai_os
DB_USER=root
DB_PASS=

# ============================================================
# Security — CHANGE THESE IN PRODUCTION
# Generate with: php -r "echo bin2hex(random_bytes(32));"
# ============================================================
JWT_SECRET=your_jwt_secret_minimum_32_characters_here
ENCRYPTION_KEY=your_32_byte_encryption_key_here!!

# ============================================================
# AI Providers
# ============================================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ELEVENLABS_API_KEY=
STABILITY_API_KEY=

# ============================================================
# Social Platform OAuth Credentials
# ============================================================

# Meta (Facebook + Instagram via Graph API)
META_APP_ID=
META_APP_SECRET=

# Twitter / X (OAuth 2.0 PKCE)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# LinkedIn OAuth 2.0
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# TikTok Open Platform
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# YouTube / Google OAuth 2.0
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Pinterest
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Snapchat
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# ============================================================
# Email (SMTP)
# ============================================================
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME="SociAI OS"
MAIL_ENCRYPTION=tls

# ============================================================
# File Uploads
# ============================================================
UPLOAD_DIR=/var/www/html/uploads
MAX_UPLOAD_SIZE=52428800
