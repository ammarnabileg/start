# SociAI OS Environment Configuration
# Copy this to .env and fill in your values

APP_NAME="SociAI OS"
APP_URL=http://localhost
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=UTC

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sociai_os
DB_USER=root
DB_PASS=

# Security — CHANGE THESE IN PRODUCTION (use: php -r "echo bin2hex(random_bytes(32));")
JWT_SECRET=your_jwt_secret_minimum_32_characters_here
ENCRYPTION_KEY=your_32_byte_encryption_key_here!!

# AI Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ELEVENLABS_API_KEY=
STABILITY_API_KEY=

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Meta (Facebook / Instagram)
META_APP_ID=
META_APP_SECRET=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Twitter / X
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# YouTube / Google
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Pinterest
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Snapchat
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=

# Email (SMTP)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME="SociAI OS"
MAIL_ENCRYPTION=tls

# Uploads
UPLOAD_DIR=/var/www/html/uploads
MAX_UPLOAD_SIZE=52428800
